# Raw participant-level data should stay local unless the IRB/data-sharing plan
# explicitly allows release.
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

outputs/*
!outputs/.gitkeep
!outputs/tables/
outputs/tables/*
!outputs/tables/.gitkeep
!outputs/figures/
outputs/figures/*
!outputs/figures/.gitkeep

.Rproj.user/
.Rhistory
.RData
.Ruserdata
renv/library/
renv/local/
renv/staging/
r-lib/
project-docs/
*.log
